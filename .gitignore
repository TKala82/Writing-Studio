# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Private, out-of-band evaluation material
/scenarios-vault/
**/behavior_scenarios*.md

# Launch audit / Playwright artifacts
/artifacts/
/playwright-report/
/test-results/
