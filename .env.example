# Convex (generated by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Clerk (pull with: npx clerk@latest env pull)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Frontend API URL / JWT issuer — also set on the Convex deployment
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev
CLERK_FRONTEND_API_URL=https://your-app.clerk.accounts.dev

# Direct model providers
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model routing (swap models without changing code)
GOOGLE_ANALYSIS_MODEL=gemini-3-flash-preview
ANTHROPIC_REWRITE_MODEL=claude-sonnet-5-0
OPENAI_CRITIQUE_MODEL=gpt-5.4

# Demo / evaluation tooling (never enable in production)
# PIPELINE_DEMO_MODE=1
# CURSOR_API_KEY=
# CLERK_DEMO_USER_ID=
